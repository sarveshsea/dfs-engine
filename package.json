{
  "name": "buzzr-dfs-settlement-os",
  "version": "2.0.0",
  "private": true,
  "description": "Monorepo for Buzzr DFS Settlement OS packages.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces",
    "lint": "eslint packages/*/src packages/*/tests",
    "format": "prettier --write \"packages/*/{src,tests,examples}/**/*.{ts,json,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"packages/*/{src,tests,examples}/**/*.{ts,json,md}\" \"*.{json,md}\"",
    "docs": "npm run docs --workspace @buzzr/dfs-engine",
    "bench": "npm run bench --workspace @buzzr/dfs-engine",
    "pack:smoke": "npm pack --workspaces --dry-run"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.19.18",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.6"
  }
}
