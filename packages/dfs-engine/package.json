{
  "name": "@buzzr/dfs-engine",
  "version": "2.0.0",
  "description": "Buzzr DFS Settlement OS core: pure grading, policy-aware payouts, and provider-ready settlement orchestration.",
  "license": "MIT",
  "author": "Sarvesh Chidambaram",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "docs": "typedoc",
    "lint": "eslint src tests",
    "format": "prettier --write src tests examples",
    "format:check": "prettier --check src tests examples",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "keywords": [
    "dfs",
    "daily-fantasy",
    "prizepicks",
    "underdog",
    "sports-betting",
    "parlay",
    "props",
    "grading",
    "payouts",
    "nba",
    "nfl",
    "mlb",
    "nhl",
    "soccer",
    "betting",
    "settlement",
    "typescript"
  ],
  "homepage": "https://github.com/sarveshsea/dfs-engine",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarveshsea/dfs-engine.git"
  },
  "bugs": {
    "url": "https://github.com/sarveshsea/dfs-engine/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
